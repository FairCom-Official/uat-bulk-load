# Settings for the FairCom vs MariaDB bulk-load benchmark. Adjust as needed.

# ---------------------------------------------------------------------------
# Container images
# ---------------------------------------------------------------------------
FAIRCOM_IMAGE=faircomteam/edge:latest

# Intended production image is the Docker Hardened Image (DHI) for MariaDB:
#   https://hub.docker.com/hardened-images/catalog/dhi/mariadb
# DHI images require a Docker Hardened Images subscription and are mirrored into
# your own Docker Hub namespace. Once mirrored, set MARIADB_IMAGE to your
# reference, e.g.:
#   MARIADB_IMAGE=<your-namespace>/dhi-mariadb:12.3
# The default below uses the official upstream image so the demo runs out of the
# box for anyone without a DHI subscription.
MARIADB_IMAGE=mariadb:11.8

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------
FAIRCOM_HTTP_PORT=8080
MARIADB_PORT=3307

# ---------------------------------------------------------------------------
# FairCom credentials / connection (JSON Action REST API)
# ---------------------------------------------------------------------------
FAIRCOM_URL=http://localhost:8080/api
FAIRCOM_USER=ADMIN
FAIRCOM_PASSWORD=ADMIN

# ---------------------------------------------------------------------------
# MariaDB credentials / connection
# ---------------------------------------------------------------------------
MARIADB_ROOT_PASSWORD=benchmark
MARIADB_DATABASE=benchmark
MARIADB_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# Benchmark settings
# ---------------------------------------------------------------------------
# Number of rows in the shared sample dataset. Both MariaDB and FairCom load
# this exact same data, so this controls the size of the whole benchmark.
ROW_COUNT=3000000

# Rows per insertRecords request sent to FairCom (FairCom loader only).
FAIRCOM_BATCH_SIZE=5000

# Number of concurrent threads posting batches to FairCom in parallel
# (FairCom loader only). 1 = sequential; ~4 is typically fastest.
FAIRCOM_WORKERS=4

TABLE_NAME=sensor_readings
